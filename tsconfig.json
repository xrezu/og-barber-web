{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":      ["./src/*"],
      "@media/*": ["./src/assets/*"]
    },
    "jsx":              "react-jsx",
    "jsxImportSource":  "react",
    "noUnusedLocals":    true,
    "noUnusedParameters": true
  }
}
