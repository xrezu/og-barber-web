---
import Layout        from '../layouts/Layout.astro'
import Navbar        from '../components/Navbar/Navbar'
import Hero          from '../components/sections/Hero/Hero'
import Services      from '../components/sections/Services/Services'
import BookingCTA    from '../components/sections/BookingCTA/BookingCTA.astro'
import Gallery       from '../components/sections/Gallery/Gallery'
import About         from '../components/sections/About/About'
import Testimonials  from '../components/sections/Testimonials/Testimonials.astro'
import Location      from '../components/sections/Location/Location'
import Footer        from '../components/sections/Footer/Footer'
import WhatsAppFloat from '../components/WhatsAppFloat/WhatsAppFloat'
---

<Layout>
  <Navbar client:load />

  <main>
    <Hero client:load />

    <Services client:visible />

    <!-- CTA tras servicios: usuario acaba de ver precios → momento de conversión -->
    <BookingCTA
      eyebrow="¿Te convencemos?"
      headline="Pide tu cita ahora"
      sub="Disponibilidad en tiempo real · Confirmación inmediata"
    />

    <Gallery  client:visible />
    <About    client:visible />
    <Testimonials />

    <!-- CTA antes del footer: último empujón antes de que salga -->
    <BookingCTA
      eyebrow="No lo dejes para después"
      headline="Tu próximo corte te está esperando"
      sub="Reserva en 30 segundos · Sin llamadas · Sin esperas"
    />

    <Location client:visible />
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
