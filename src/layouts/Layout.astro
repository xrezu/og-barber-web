---
import '../styles/global.css'

interface Props {
  title?:       string
  description?: string
}

const {
  title       = 'OG Barber Studio | Barbería en Getafe, Madrid — Cortes, Barba y Diseño',
  description = 'OG Barber Studio, barbería premium en Getafe (Madrid). Cortes fade, arreglo de barba, diseños y tratamientos capilares. Reserva tu cita online en Booksy o por WhatsApp. Más de 500 clientes satisfechos.',
} = Astro.props
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Primary SEO ────────────────────────────────────────────────── -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="keywords"     content="barbería Getafe, barbería Madrid, corte de pelo Getafe, barba Getafe, fade Getafe, OG Barber Studio, barbería premium, corte hombre Getafe, peluquería hombre Madrid" />
    <meta name="author"       content="OG Barber Studio" />
    <meta name="robots"       content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical"     href="https://ogbarberstudio.vercel.app/" />

    <!-- ── Geo / Local ───────────────────────────────────────────────── -->
    <meta name="geo.region"    content="ES-MD" />
    <meta name="geo.placename" content="Getafe, Madrid" />
    <meta name="geo.position"  content="40.3084;-3.7317" />
    <meta name="ICBM"          content="40.3084, -3.7317" />

    <!-- ── Open Graph ────────────────────────────────────────────────── -->
    <meta property="og:type"         content="website" />
    <meta property="og:site_name"    content="OG Barber Studio" />
    <meta property="og:url"          content="https://ogbarberstudio.vercel.app/" />
    <meta property="og:title"        content="OG Barber Studio | Barbería Premium en Getafe, Madrid" />
    <meta property="og:description"  content="Cortes fade, barba y diseños en Getafe. Más de 8 años de experiencia y +500 clientes. Reserva online en Booksy." />
    <meta property="og:image"        content="https://ogbarberstudio.vercel.app/og-image.jpg" />
    <meta property="og:image:alt"    content="OG Barber Studio — Barbería premium en Getafe, Madrid" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"       content="es_ES" />

    <!-- ── Twitter Card ──────────────────────────────────────────────── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="OG Barber Studio | Barbería Premium en Getafe" />
    <meta name="twitter:description" content="Cortes fade, barba y diseños. Reserva tu cita online." />
    <meta name="twitter:image"       content="https://ogbarberstudio.vercel.app/og-image.jpg" />

    <!-- ── Favicon ───────────────────────────────────────────────────── -->
    <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon"                      href="/favicon.svg" />
    <meta name="theme-color"             content="#0A0A0A" />
    <meta name="msapplication-TileColor" content="#0A0A0A" />

    <!-- ── Fonts preconnect ───────────────────────────────────────────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- ── Preload hero image (LCP) ──────────────────────────────────── -->
    <link rel="preload" as="image" href="/og-image.jpg" />

    <!-- ── JSON-LD Structured Data ───────────────────────────────────── -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BarberShop",
          "@id": "https://ogbarberstudio.vercel.app/#business",
          "name": "OG Barber Studio",
          "description": "Barbería premium en Getafe, Madrid. Especializada en cortes fade, arreglo de barba, diseños y tratamientos capilares.",
          "url": "https://ogbarberstudio.vercel.app/",
          "telephone": "+34600000000",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Calle Madrid 45",
            "addressLocality": "Getafe",
            "addressRegion": "Madrid",
            "postalCode": "28901",
            "addressCountry": "ES"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 40.3084,
            "longitude": -3.7317
          },
          "openingHoursSpecification": [
            {
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
              "opens": "10:00",
              "closes": "20:30"
            },
            {
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": "Saturday",
              "opens": "10:00",
              "closes": "15:00"
            }
          ],
          "priceRange": "€€",
          "currenciesAccepted": "EUR",
          "paymentAccepted": "Cash, Credit Card",
          "image": "https://ogbarberstudio.vercel.app/og-image.jpg",
          "logo": "https://ogbarberstudio.vercel.app/favicon.svg",
          "sameAs": ["https://ogbarberstudio67.booksy.com/a"],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Servicios OG Barber Studio",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Corte OG" }, "price": "15", "priceCurrency": "EUR" },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Corte y Barba OG" }, "price": "24", "priceCurrency": "EUR" },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Arreglo de Barba OG" }, "price": "13", "priceCurrency": "EUR" }
            ]
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "5",
            "reviewCount": "500",
            "bestRating": "5",
            "worstRating": "1"
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://ogbarberstudio.vercel.app/#website",
          "url": "https://ogbarberstudio.vercel.app/",
          "name": "OG Barber Studio",
          "description": "Barbería premium en Getafe, Madrid",
          "inLanguage": "es-ES"
        }
      ]
    }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
